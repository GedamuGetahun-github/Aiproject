# ------------------ AUDIO FEATURE EXTRACTION ------------------
def extract_audio_features(audio_path):
    """Extract pitch and MFCC features from audio file (32 features)"""
    try:
        y, sr = librosa.load(audio_path, sr=16000, duration=5)
        
        # Pitch features
        pitches, magnitudes = librosa.piptrack(y=y, sr=sr)
        pitch_values = pitches[pitches > 0]
        
        if len(pitch_values) > 0:
            pitch_mean = np.mean(pitch_values)
            pitch_std = np.std(pitch_values)
            pitch_max = np.max(pitch_values)
            pitch_min = np.min(pitch_values)
        else:
            pitch_mean = pitch_std = pitch_max = pitch_min = 0
        
        # MFCC features
        mfccs = librosa.feature.mfcc(y=y, sr=sr, n_mfcc=13)
        mfcc_means = np.mean(mfccs, axis=1)
        mfcc_stds = np.std(mfccs, axis=1)
        
        # Energy
        energy = np.mean(librosa.feature.rms(y=y))
        
        # Zero crossing rate
        zcr = np.mean(librosa.feature.zero_crossing_rate(y=y))
        
        # Combine all features (32 features total)
        features = np.concatenate([
            [pitch_mean, pitch_std, pitch_max, pitch_min, energy, zcr],
            mfcc_means,
            mfcc_stds
        ])
        
        return features
    except Exception as e:
        st.error(f"Audio extraction error: {e}")
        return None

# ------------------ VIDEO EMOTION ANALYSIS ------------------
def analyze_face_emotion(frame):
    """Analyze a single frame for emotions"""
    if not DEEPFACE_AVAILABLE:
        return "neutral", 0.0
    
    try:
        rgb_frame = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
        analysis = DeepFace.analyze(img_path=rgb_frame, actions=['emotion'], 
                                     enforce_detection=False, silent=True)
        emotion = analysis[0]['dominant_emotion']
        
        # IMPROVEMENT 3: Raised neutral score so it doesn't always pull result down
        deception_emotions = {'fear': 0.9, 'surprise': 0.7, 'disgust': 0.8, 
                              'angry': 0.6, 'sad': 0.5, 'neutral': 0.4, 'happy': 0.2}
        deception_prob = deception_emotions.get(emotion, 0.3)
        
        return emotion, deception_prob
    except:
        return "unknown", 0.0

