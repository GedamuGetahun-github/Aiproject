        audio_value = st.audio_input("Click to record")
        
        if audio_value is not None:
            audio_path = "live_audio.wav"
            with open(audio_path, "wb") as f:
                f.write(audio_value.getbuffer())
            
            audio_features = extract_audio_features(audio_path)
            audio_model, model_loaded = load_audio_model()
            
            if audio_model is not None and audio_features is not None:
                try:
                    audio_prediction = audio_model.predict([audio_features])[0]
                    audio_proba = audio_model.predict_proba([audio_features])[0]
                    audio_prob = audio_proba[1] if audio_prediction == 1 else audio_proba[0]
                except Exception as e:
                    st.warning(f"Audio model error: {e}. Using fallback.")
                    audio_prob = 0.5
            else:
                st.warning("Audio model not loaded. Using feature-based estimation.")
                audio_prob = 0.5
            
            # IMPROVEMENT 1: MAX fusion instead of average
            fused_score = max(audio_prob, video_score)
            final_prediction = "DECEPTION DETECTED" if fused_score > 0.5 else "TRUTH"
            result_class = "result-lie" if fused_score > 0.5 else "result-truth"
            
            st.markdown(f"<div class='{result_class}'>{final_prediction}</div>", unsafe_allow_html=True)
            st.markdown(f"**Fused Confidence:** {fused_score:.1%}")
            
            col1, col2 = st.columns(2)
            with col1:
                st.metric("Audio Deception Score", f"{audio_prob:.1%}")
            with col2:
                st.metric("Video Deception Score", f"{video_score:.1%}")

